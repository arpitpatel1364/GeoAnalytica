# ── Database ──────────────────────────────────────────────
# Use 'postgres' for Docker, 'localhost' for local non-Docker run
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/geoanalytica

# ── Redis ─────────────────────────────────────────────────
# Use 'redis' for Docker, 'localhost' for local non-Docker run
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Security ──────────────────────────────────────────────
SECRET_KEY=
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost", "http://localhost:80", "http://localhost:8000"]

# ── AI (Optional but recommended) ─────────────────────────
ANTHROPIC_API_KEY=

# ── Email Alerts (Optional) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── External APIs (Optional) ──────────────────────────────
BRAVE_API_KEY=
SERP_API_KEY=
